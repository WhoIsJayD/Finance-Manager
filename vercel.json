{
  "version": 2,
  "builds": [
    {
      "src": "./app.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["templates/**", "static/**", "app.py"],
        "excludeFiles": ["**/node_modules/**", "**/.git/**", "**/__pycache__/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/"
    }
  ]
}
